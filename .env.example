# ─── Server ────────────────────────────────────────────────────
PORT=3000

# ─── TLS / HTTPS ───────────────────────────────────────────────
# Set to 'true' when running behind HTTPS (enables Secure cookie + HSTS)
HTTPS=false

# ─── Session ───────────────────────────────────────────────────
# Timeout in milliseconds (default: 7200000 = 2 hours)
SESSION_TIMEOUT_MS=7200000

# ─── Storage paths ─────────────────────────────────────────────
# Absolute paths for persistent volumes (e.g. Railway, Render)
# DB_PATH=/data/data.db
# UPLOADS_PATH=/data/uploads

# ─── Web Push notifications (VAPID) ────────────────────────────
# Required for background push to keep working across redeploys.
# Without these, keys are generated and stored in the DB; if the DB is
# recreated (no persistent volume) the keys change and existing browser
# subscriptions break ("Push subscription exists but sending failed").
# Generate once with:  npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@yourdomain.com

# ─── Admin account password (required for production) ──────────
# Set this before first deployment. Used by auto-seed on startup.
# Username is always: admin
# NEVER commit the actual value — set it in the deployment platform.
# ADMIN_PASSWORD=

# ─── Other demo account passwords (optional) ───────────────────
# If not set, secure random passwords are generated and printed once.
# DEMO_ADMIN_PASSWORD=change-me-demo-admin
# DEMO_FM_PASSWORD=
# DEMO_MANAGER_PASSWORD=
# DEMO_SUPERVISOR_PASSWORD=
# DEMO_WORKER_PASSWORD=
# DEMO_HOSPITALITY_PASSWORD=change-me-demo-hospitality
