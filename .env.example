# ─── Server ────────────────────────────────────────────────────
PORT=3000

# ─── TLS / HTTPS ───────────────────────────────────────────────
# Set to 'true' when running behind HTTPS (enables Secure cookie + HSTS)
HTTPS=false

# ─── Session ───────────────────────────────────────────────────
# Timeout in milliseconds (default: 7200000 = 2 hours)
SESSION_TIMEOUT_MS=7200000

# ─── Storage paths ─────────────────────────────────────────────
# Absolute paths for persistent volumes (e.g. Railway, Render)
# DB_PATH=/data/data.db
# UPLOADS_PATH=/data/uploads

# ─── Demo seed passwords (used by scripts/seed-demo.js only) ───
# Leave blank to auto-generate random passwords (printed to console once)
# DEMO_ADMIN_PASSWORD=
# DEMO_FM_PASSWORD=
# DEMO_MANAGER_PASSWORD=
# DEMO_SUPERVISOR_PASSWORD=
# DEMO_WORKER_PASSWORD=
